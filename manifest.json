{
  "manifest_version": 3,
  "name": "TermCheck - AI Legal Assistant",
  "version": "1.0.0",
  "description": "Analyze Terms of Service and Privacy Policies for red flags.",
  "icons": {
    "16": "termcheck_icon16.png",
    "32": "termcheck_icon32.png",
    "48": "termcheck_icon48.png",
    "128": "termcheck_icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "termcheck_icon16.png",
      "32": "termcheck_icon32.png",
      "48": "termcheck_icon48.png",
      "128": "termcheck_icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "type": "module"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}