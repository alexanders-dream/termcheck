{
  "manifest_version": 3,
  "name": "TermCheck - AI Legal Assistant",
  "version": "1.1.0",
  "description": "Analyze Terms of Service, Privacy Policies, and Contracts for red flags.",
  "icons": {
    "16": "termcheck_icon16.png",
    "32": "termcheck_icon32.png",
    "48": "termcheck_icon48.png",
    "128": "termcheck_icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "termcheck_icon16.png",
      "32": "termcheck_icon32.png",
      "48": "termcheck_icon48.png",
      "128": "termcheck_icon128.png"
    },
    "default_title": "TermCheck - Analyze Legal Documents"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "type": "module"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open TermCheck"
    }
  }
}
